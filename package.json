{
  "name": "kinocat-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for kinocat — time-extended kinodynamic planning for the web",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm --filter kinocat build && pnpm --filter @kinocat/three build",
    "dev": "pnpm --filter kinocat build && pnpm --filter @kinocat/demos dev",
    "typecheck": "pnpm --filter kinocat build && pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "bench": "vitest bench --run",
    "size": "pnpm --filter kinocat size",
    "verify": "pnpm typecheck && pnpm test && pnpm --filter kinocat build && pnpm size"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
