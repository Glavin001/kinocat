{
  "name": "@kinocat/demos",
  "version": "0.0.0",
  "description": "kinocat demos — Next.js web app",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "e2e:carchase": "node test/carchase-e2e.mjs",
    "train": "tsx scripts/train.ts",
    "train:quick": "tsx scripts/train.ts --profile=quick --out=demos/public/models/v2-ci.json",
    "train:sweep": "tsx scripts/train.ts --profile=sweep",
    "train:overnight": "tsx scripts/train.ts --profile=overnight",
    "compare:primitives": "tsx scripts/compare-primitives.ts",
    "model:backfill-support": "tsx scripts/backfill-input-support.ts",
    "race": "tsx scripts/race.ts",
    "race:quick": "tsx scripts/race.ts --quick --no-parametric --ledger=docs/race-results",
    "ablation": "tsx scripts/ablation.ts",
    "ablation:quick": "tsx scripts/ablation.ts --laps=3 --max-sim=180",
    "controller-bench": "tsx scripts/controller-bench.ts",
    "controller-bench:json": "tsx scripts/controller-bench.ts --json=docs/controller-bench/latest.json"
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "^0.14.0",
    "@kinocat/three": "workspace:*",
    "kinocat": "workspace:*",
    "navcat": "0.4.1",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1",
    "three": "^0.180.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.180.0",
    "tsx": "^4.22.3",
    "typescript": "^5.7.0"
  }
}
